<?xml version="1.0" encoding="UTF-8"?>
<MARS_EXPLORATION_DATABASE>
  <!-- INITIAL CONCEPT (NOT NORMALIZED) -->
  <SPACEMISSIONS>
    <id PrimaryKey="true"></id>
    <missionName></missionName>
    <date></date>
    <missionCompany></missionCompany>
    <country></country>
    <TransporterCompany></TransporterCompany>
    <TransporterCountry></TransporterCountry>
    <transportVehicleName></transportVehicleName>
    <description></description>
    <missionType></missionType>
    <crew></crew>
    <duration></duration>
    <departureLocation></departureLocation>
    <landingLocation></landingLocation>
    <budget></budget>
    <status></status>
    <mainDeviceName></mainDeviceName>
    <mass></mass>
    <dimensions></dimensions>
    <communicationTech></communicationTech>
    <controlCenter></controlCenter>
    <FuelType></FuelType>
    <distance></distance>
  </SPACEMISSIONS>
  <!-- ====================NORMALIZATION==================== -->
  <!-- ==================REGION => GENERAL================== -->
  <OPERATIONS>
    <OPERATION_ID primary_key="true"></OPERATION_ID>
    <OPERATION_NAME></OPERATION_NAME>
    <OPERATION_CATEGORY_ID ForeignKey="true" References="OPERATION_CATEGORY"></OPERATION_CATEGORY_ID>
    <OPERATION_STATUS ForeignKey="true" References="OPERATION_STATUS"></OPERATION_STATUS>
  </OPERATIONS>

  <OPERATION_CATEGORY>
    <OPERATION_CATEGORY_ID PrimaryKey="true"></OPERATION_CATEGORY_ID>
    <OPERATION_CATEGORY_NAME></OPERATION_CATEGORY_NAME>
  </OPERATION_CATEGORY>

  <OPERATION_STATUS>
    <OPERATION_STATUS_ID PrimaryKey="true"></OPERATION_STATUS_ID>
    <OPERATION_STATUS_NAME></OPERATION_STATUS_NAME>
  </OPERATION_STATUS>
  
  <DEVICES>
    <DEVICE_ID PrimaryKey="true"></DEVICE_ID>
    <DEVICE_SERIAL_NUMBER></DEVICE_SERIAL_NUMBER>
    <DEVICE_COMPANY_ID ForeignKey="true"></DEVICE_COMPANY_ID>
    <DEVICE_MANUFACTURE_DATE></DEVICE_MANUFACTURE_DATE>
    <DEVICE_NAME></DEVICE_NAME>
    <DEVICE_TYPE></DEVICE_TYPE>
    <DEVICE_MASS></DEVICE_MASS>
    <DEVICE_WIDTH></DEVICE_WIDTH>
    <DEVICE_HEIGHT></DEVICE_HEIGHT>
    <DEVICE_COMUNICATION_TECH></DEVICE_COMUNICATION_TECH>
    <DEVICE_FUEL_TYPE></DEVICE_FUEL_TYPE>
    <DEVICE_LAST_MAINTENANCE_DATE></DEVICE_LAST_MAINTENANCE_DATE>
    <DEVICE_NEXT_MAINTENANCE_DATE></DEVICE_NEXT_MAINTENANCE_DATE>
  </DEVICES>

  <COMPANIES>
    <COMPANY_ID PrimaryKey="true"></COMPANY_ID>
    <COMPANY_NAME></COMPANY_NAME>
    <COMPANY_COUNTRY></COMPANY_COUNTRY>
    <COMPANY_CEO></COMPANY_CEO>
    <COMPANY_CAPITAL></COMPANY_CAPITAL>
    <COMPANY_TYPE></COMPANY_TYPE>
  </COMPANIES>
  <!-- ====================ENDREGION GENERAL==================== -->
  <!-- ================================REGION => LOGISTICS================================ -->  
  <SPACE_LOGISTICS>
    <MISSION_ID PrimaryKey="true"></MISSION_ID>
    <OPERATION_ID ForeignKey="true"></OPERATION_ID>
    <MISSION_NAME></MISSION_NAME>
    <MISSION_COMPANY_ID ForeignKey="true"></MISSION_COMPANY_ID>
    <MISSION_TRANSPORT_VEHICLE_ID ForeignKey="true"></MISSION_TRANSPORT_VEHICLE_ID>
    <MISSION_MAIN_DEVICE_ID ForeignKey="true"></MISSION_MAIN_DEVICE_ID>
    <MISSION_TYPE_ID ForeignKey="true"></MISSION_TYPE_ID>
    <DESCRIPTION></DESCRIPTION>
    <LAUNCH_DATE></LAUNCH_DATE>
    <LANDING_DATE></LANDING_DATE>
    <DEPARTURE_LOCATION></DEPARTURE_LOCATION>
    <LANDING_LOCATION></LANDING_LOCATION>
    <BUDGET></BUDGET>
  </SPACE_LOGISTICS>
  
  <LOGISTICS_OPERATION_TYPE>
    <OPERATION_TYPE_ID PrimaryKey="true"></OPERATION_TYPE_ID>
    <OPERATION_TYPE_NAME></OPERATION_TYPE_NAME>
  </LOGISTICS_OPERATION_TYPE>

  <!-- ================================ENDREGION => LOGISTICS================================ -->
  <!-- ================================REGION => SCIENTIFIC DATA================================ -->
  <SCIENTIFIC_PROSPECTION_DATA>
    <TASK_ID PrimaryKey="true"></TASK_ID>
    <OPERATION_ID ForeignKey="true" References="OPERATIONS"></OPERATION_ID>
    <TASK_DEVICE_ID></TASK_DEVICE_ID>
    <TASK_TIME></TASK_TIME>
    <TASK_LOCATION></TASK_LOCATION>
    <TASK_TYPE ForeignKey="true" References="SCIENTIFIC_TASK_TYPES"></TASK_TYPE>
    <TASK_EVENT_TYPE ForeignKey="true" References="TASK_EVENT_TYPE_NAME"></TASK_EVENT_TYPE>
    <TASK_RAW_DATA></TASK_RAW_DATA>
  </SCIENTIFIC_PROSPECTION_DATA>

  <SCIENTIFIC_TASK_TYPES>
    <TASK_TYPE_ID PrimaryKey="true"></TASK_TYPE_ID>
    <TASK_TYPE_NAME></TASK_TYPE_NAME>
  </SCIENTIFIC_TASK_TYPES>
  
  <TASK_EVENT_TYPE>
    <TASK_EVENT_TYPE_ID PrimaryKey="true"></TASK_EVENT_TYPE_ID>
    <TASK_EVENT_TYPE_NAME></TASK_EVENT_TYPE_NAME>
  </TASK_EVENT_TYPE>
  <!-- ================================ENDREGION => SCIENTIFIC DATA================================ -->
</MARS_EXPLORATION_DATABASE>

